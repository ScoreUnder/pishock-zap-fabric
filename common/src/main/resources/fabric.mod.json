{
  "schemaVersion": 1,
  "id": "pishock-zap",
  "version": "${version}",
  "name": "PiShock-Zap",
  "description": "Connect PiShock/OpenShock devices to Minecraft! Like hardcore mode, but with real consequences",
  "authors": ["score"],
  "contact": {},
  "license": "GPLv3",
  "environment": "client",
  "entrypoints": {
    "client": [
      "moe.score.pishockzap.PishockZapMod"
    ],
    "modmenu": [
      "moe.score.pishockzap.PishockZapModConfigMenu"
    ]
  },
  "mixins": [
    {
      "config": "pishock-zap.client.mixins.json",
      "environment": "client"
    },
    {
      "config": "pishock-zap.clothconfig.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "cloth-config2": "*",
    "fabricloader": "${fabric_loader_version_compat}",
    "${fabric_api_mod_name}": "*",
    "minecraft": "${minecraft_version_compat}",
    "java": ">=${java_version}"
  }
}
